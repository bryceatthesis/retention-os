# Lifecycle Command Center — environment variables
#
# Copy to `.env` for local development. In CI, configure these as
# GitHub Actions secrets on the repository (Settings → Secrets → Actions).
# `.env` is gitignored. Never commit real keys.
#
# Preflight (scripts/preflight.ts) runs before any data fetch and verifies:
#   1. Each required key is present
#   2. Each key resolves via GET /api/accounts/ (i.e. has accounts:read)
#   3. The two Klaviyo keys point to DIFFERENT org_ids
# A failure on any of those aborts the workflow loudly.

# ---- Klaviyo ----
# Two distinct organizations. Two distinct private API keys.
# Each key needs (at minimum) read scopes on: accounts, campaigns, flows,
# templates, lists, segments, metrics. Generate at:
#   https://www.klaviyo.com/account#api-keys-tab
KLAVIYO_API_KEY_THESIS=
KLAVIYO_API_KEY_STASIS=

# Klaviyo API revision pin — do not change without reproducibility review.
# Documented in scripts/fetch/klaviyo.ts.
KLAVIYO_API_REVISION=2024-10-15

# ---- ReCharge (v1: stubbed if missing) ----
# When provisioned, both should be set. v1 only validates that the key
# resolves; subscription-health pages are deferred to v2.
RECHARGE_API_KEY_THESIS=
RECHARGE_API_KEY_STASIS=

# ---- Build / deploy ----
# Override the deployed site URL (set automatically in the GitHub Actions
# deploy workflow — only needed locally if testing absolute URLs).
# LCC_SITE_URL=https://bryceatthesis.github.io/retention-os

# Set to "true" only if hosting at the apex `username.github.io` site.
# LCC_USER_SITE=false
