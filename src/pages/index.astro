---
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');

interface Tool {
  name: string;
  status: 'live' | 'planned';
  description: string;
  href?: string;
  detail?: string;
}

const tools: Tool[] = [
  {
    name: 'Lifecycle Command Center',
    status: 'live',
    description: 'Daily-scan dashboard for Klaviyo creative performance, deliverability, and flow inventory across Thesis & Stasis.',
    href: `${baseUrl}/lifecycle-command-center/`,
  },
  {
    name: 'Subscription health (v2)',
    status: 'planned',
    description: 'ReCharge-driven view of sub starts, cancels, dunning recovery, plan upgrades. Lands when ReCharge keys + holdout instrumentation are in place.',
  },
  {
    name: 'Cohort retention curves (v2)',
    status: 'planned',
    description: 'Warehouse-driven 30/60/90/180d cohort retention by acquisition channel and product. Pending warehouse access.',
  },
];

const refs: Array<{ name: string; href: string; description: string }> = [
  {
    name: 'Knowledge',
    href: 'https://github.com/bryceatthesis/retention-os/tree/main/knowledge',
    description: 'Metric definitions, segments, lifecycle stages, OKRs, data sources, glossary, flow inventory.',
  },
  {
    name: 'Playbooks',
    href: 'https://github.com/bryceatthesis/retention-os/tree/main/playbooks',
    description: 'Step-by-step SOPs: churn investigation, lifecycle audit, winback, new segment launch.',
  },
  {
    name: 'Experiments',
    href: 'https://github.com/bryceatthesis/retention-os/tree/main/experiments',
    description: 'Quarter-organized experiment write-ups.',
  },
  {
    name: 'Repo',
    href: 'https://github.com/bryceatthesis/retention-os',
    description: 'Source for everything in Retention OS, including this site.',
  },
];
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="noindex,nofollow" />
    <title>Retention OS</title>
    <link rel="stylesheet" href={`${baseUrl}/assets/site.css`} />
  </head>
  <body>
    <main class="ros-landing">
      <header>
        <h1>Retention OS</h1>
        <p>Internal tooling and knowledge for Thesis's retention org. Public site, but PII-free — Klaviyo aggregates only. See <a href="https://github.com/bryceatthesis/retention-os">the repo</a> for source.</p>
      </header>

      <section>
        <h2>Tools</h2>
        <div class="ros-tools">
          {tools.map((t) => {
            const Tag = t.href ? 'a' : 'div';
            return (
              <Tag class:list={['ros-tool', `ros-tool--${t.status}`]} href={t.href}>
                <div class="ros-tool__head">
                  <strong>{t.name}</strong>
                  <span class:list={['badge', t.status === 'live' ? 'badge--good' : 'badge--pending']}>
                    {t.status === 'live' ? 'Live' : 'Planned'}
                  </span>
                </div>
                <p>{t.description}</p>
                {t.detail && <span class="muted" style="font-size: 12px;">{t.detail}</span>}
              </Tag>
            );
          })}
        </div>
      </section>

      <section>
        <h2>Reference</h2>
        <ul class="ros-refs">
          {refs.map((r) => (
            <li>
              <a href={r.href}><strong>{r.name}</strong></a>
              <span class="muted"> — {r.description}</span>
            </li>
          ))}
        </ul>
      </section>
    </main>
  </body>
</html>
<style is:global>
  body { margin: 0; background: #f8f8f7; color: #1a1a1a; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; line-height: 1.5; }
  .ros-landing { max-width: 880px; margin: 0 auto; padding: 48px 24px; }
  .ros-landing > header { margin-bottom: 32px; }
  .ros-landing h1 { margin: 0 0 8px 0; font-size: 32px; letter-spacing: -0.02em; }
  .ros-landing h2 { margin: 32px 0 12px 0; font-size: 18px; }
  .ros-landing p { margin: 0 0 8px 0; }
  .ros-tools { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 12px; }
  .ros-tool { display: block; padding: 16px; border: 1px solid #e3e2df; border-radius: 8px; background: white; text-decoration: none; color: inherit; }
  a.ros-tool:hover { border-color: #1d4ed8; }
  .ros-tool--planned { opacity: 0.6; }
  .ros-tool__head { display: flex; justify-content: space-between; align-items: center; gap: 8px; margin-bottom: 4px; }
  .ros-tool p { font-size: 13px; color: #595959; margin: 4px 0 0 0; }
  .ros-refs { list-style: none; padding: 0; margin: 0; }
  .ros-refs li { padding: 6px 0; border-bottom: 1px solid #e3e2df; font-size: 14px; }
  .ros-refs li:last-child { border-bottom: 0; }
</style>
