---
/**
 * Refill / attributed-revenue caveat — rendered inline above (or beside)
 * any chart, table, or value that shows Klaviyo's `Placed Order` attribution.
 *
 * Per CLAUDE.md rule #7: this caveat MUST appear at the chart, not in
 * a global banner or footer. Not collapsible.
 */
interface Props {
  /** Optional shorter rendering for tight column headers. */
  variant?: 'block' | 'inline';
}
const { variant = 'block' } = Astro.props;
const text = "Klaviyo `Placed Order` attribution credits orders within a 5-day window of any send/open/click and includes auto-renew subscription orders. Substantially overstates incremental lift for subscription-heavy revenue. See CLAUDE.md rule #7.";
---
{variant === 'block' ? (
  <p class="refill-caveat" role="note">⚠ {text}</p>
) : (
  <span class="refill-caveat" role="note" style="display:inline-block; margin:0;">⚠ {text}</span>
)}
